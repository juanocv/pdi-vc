\contentsline {figure}{\numberline {4.1}{\ignorespaces Imagem com moedas de vários tipos. Crédito: GAZI.MD.AHAD (CC BY-SA 4.0).}}{133}{figure.caption.106}%
\contentsline {figure}{\numberline {4.2}{\ignorespaces Comparação dos pré-processamentos: imagem \textbar {} histograma+T* \textbar {} σ²B(T) \textbar {} Otsu. A melhor separação bimodal indica o limiar mais confiável.}}{135}{figure.caption.107}%
\contentsline {figure}{\numberline {4.3}{\ignorespaces Critério de Otsu sobre imagem com CLAHE: histograma com T* marcado (esquerda) e variância inter-classe σ²B em função de T (direita). O pico alto e estreito confirma a boa separação bimodal.}}{137}{figure.caption.108}%
\contentsline {figure}{\numberline {4.4}{\ignorespaces Erosão e dilatação em imagem binária 7×7 com elemento estruturante em cruz 3×3: mm.ero0 (laços didáticos) e mm.dil0 mostram o mecanismo explicitamente; mm.ero e mm.dil confirmam o resultado via OpenCV.}}{139}{figure.caption.111}%
\contentsline {figure}{\numberline {4.5}{\ignorespaces Abertura (remove ruído externo) e fechamento (preenche buracos internos) aplicados à binarização Otsu das moedas com CLAHE. Elemento estruturante: disco 13×13.}}{141}{figure.caption.114}%
\contentsline {figure}{\numberline {4.6}{\ignorespaces Comparação do clohole após Otsu em cada pré-processamento. Discos completamente preenchidos indicam boa binarização das moedas.}}{143}{figure.caption.118}%
\contentsline {figure}{\numberline {4.7}{\ignorespaces Pipeline completo de segmentação com CLAHE: Otsu → fechamento → clohole → erosão+dilatação (remoção de ruído) → abertura → edgeoff.}}{145}{figure.caption.119}%
\contentsline {figure}{\numberline {4.8}{\ignorespaces Morfologia em tons de cinza aplicada à imagem Lena: erosão (escurece), dilatação (clareia), gradiente morfológico (bordas), top-hat (detalhes brilhantes) e black-hat (detalhes escuros).}}{146}{figure.caption.124}%
\contentsline {figure}{\numberline {4.9}{\ignorespaces Componentes conexos extraídos após o pipeline CLAHE → Otsu → limpeza morfológica. Cada objeto é colorido com cor distinta e anotado com sua área em pixels.}}{148}{figure.caption.125}%
\contentsline {figure}{\numberline {4.10}{\ignorespaces Descritores de forma: circularidade anotada em cada moeda (verde ≥ 0.7 indica forma circular; vermelho \textless {} 0.7 indica oclusão ou forma irregular).}}{149}{figure.caption.126}%
\contentsline {figure}{\numberline {4.11}{\ignorespaces Pipeline watershed para separação de moedas sobrepostas: da segmentação morfológica (img\_final) até os contornos finais anotados sobre a imagem original.}}{152}{figure.caption.128}%
\contentsline {figure}{\numberline {4.12}{\ignorespaces Método do cotovelo: inércia J em função de k para a imagem de moedas. O ponto de inflexão sugere o k ótimo.}}{154}{figure.caption.130}%
\contentsline {figure}{\numberline {4.13}{\ignorespaces Segmentação k-means da imagem das moedas com k=2, 4 e 6 clusters. Cada região é preenchida com a intensidade média do seu centróide.}}{155}{figure.caption.131}%
\contentsline {figure}{\numberline {4.14}{\ignorespaces Leopard (Panthera pardus) GPS: (-19.14020, 23.81487). Crédito: C. Brück (CC BY-SA 4.0).}}{157}{figure.caption.133}%
