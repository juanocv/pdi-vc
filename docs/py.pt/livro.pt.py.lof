\contentsline {figure}{\numberline {4.31}{\ignorespaces Simulador: Limiarização Automática de Otsu}}{231}{figure.caption.167}%
\contentsline {figure}{\numberline {4.32}{\ignorespaces Simulador: Dilatação Binária Plana (mm.dil0)}}{234}{figure.caption.168}%
\contentsline {figure}{\numberline {4.33}{\ignorespaces Simulador: Erosão Binária Plana (mm.ero0)}}{236}{figure.caption.169}%
\contentsline {figure}{\numberline {4.34}{\ignorespaces Simulador: Abertura Morfológica (erosão + dilatação)}}{238}{figure.caption.170}%
\contentsline {figure}{\numberline {4.35}{\ignorespaces Simulador: Fechamento Morfológico (dilatação + erosão)}}{240}{figure.caption.171}%
\contentsline {figure}{\numberline {4.36}{\ignorespaces Simulador: Dilatação e Erosão com Pesos (mm.dil1 / mm.ero1)}}{243}{figure.caption.172}%
\contentsline {figure}{\numberline {4.37}{\ignorespaces Simulador: Gradiente Morfológico, Top-hat e Black-hat}}{245}{figure.caption.173}%
\contentsline {figure}{\numberline {4.38}{\ignorespaces Simulador: Transformada de Distância}}{247}{figure.caption.174}%
\contentsline {figure}{\numberline {4.39}{\ignorespaces Simulador: Separação de Blobs, Rotulação e Descritores}}{249}{figure.caption.175}%
\addvspace {10\p@ }
\contentsline {figure}{\numberline {5.1}{\ignorespaces Decomposição de Fourier 1D: uma onda quadrada (linha tracejada) é aproximada pela soma das primeiras senoides (linhas coloridas). Quanto mais termos, melhor a aproximação.}}{251}{figure.caption.176}%
\contentsline {figure}{\numberline {5.2}{\ignorespaces Toda frequência no espectro (ponto isolado) corresponde a uma onda senoidal 2D rotacionada no domínio espacial.}}{252}{figure.caption.177}%
\contentsline {figure}{\numberline {5.3}{\ignorespaces Diagrama conceitual do espectro de Fourier 2D centrado.}}{253}{figure.caption.180}%
\contentsline {figure}{\numberline {5.4}{\ignorespaces Experimento de troca de fase: Imagem A (moedas) e Imagem B (padrão geométrico) reconstruídas com magnitudes e fases trocadas. O resultado confirma que a estrutura visual segue a fase --- a imagem reconstruída com a fase de B se parece com B, independentemente de qual magnitude foi usada.}}{255}{figure.caption.181}%
\contentsline {figure}{\numberline {5.5}{\ignorespaces Simulador interativo da decomposição de Fourier 1D: visualização da soma de senoides com diferentes frequências, amplitudes e fases. Adicione termos e observe a convergência para formas de onda arbitrárias.}}{255}{figure.caption.182}%
\contentsline {figure}{\numberline {5.6}{\ignorespaces Comparação de eficiência: Convolução Não Separável (Espacial 2D), Separável (Espacial 1D) e via FFT.}}{257}{figure.caption.185}%
\contentsline {figure}{\numberline {5.7}{\ignorespaces Sem padding, um deslocamento severo faz a imagem vazar para o lado oposto (convolução circular).}}{258}{figure.caption.186}%
\contentsline {figure}{\numberline {5.8}{\ignorespaces Verificação do Teorema da Convolução: a diferença pixel a pixel entre a convolução espacial (cv2.filter2D) e a multiplicação em frequência (FFT) é numericamente nula --- confirmando a equivalência teórica.}}{259}{figure.caption.187}%
\contentsline {figure}{\numberline {5.9}{\ignorespaces A Dualidade Perigosa: O corte abrupto na Frequência (Cilindro) transforma-se obrigatoriamente numa Sinc espacial. Suas ondulações causam o \emph {ringing} fantasma nas bordas da imagem.}}{260}{figure.caption.188}%
\contentsline {figure}{\numberline {5.10}{\ignorespaces Filtros passa-baixa.}}{261}{figure.caption.193}%
\contentsline {figure}{\numberline {5.11}{\ignorespaces Simulador interativo de filtros no domínio da frequência.}}{262}{figure.caption.194}%
\contentsline {figure}{\numberline {5.12}{\ignorespaces Comparação entre filtros passa-baixa: Ideal (D₀=30), Gaussiano (D₀=30) e Butterworth (D₀=30, n=2). Perfis de H(u,v) ao longo de uma linha central e imagens filtradas correspondentes.}}{263}{figure.caption.195}%
\contentsline {figure}{\numberline {5.13}{\ignorespaces Filtro passa-alta Gaussiano. (a) Original; (b) Filtro passa-alta (D₀=30) - as bordas das moedas e fundo texturizado são realçados.}}{264}{figure.caption.196}%
\contentsline {figure}{\numberline {5.14}{\ignorespaces }}{265}{figure.caption.197}%
\contentsline {figure}{\numberline {5.15}{\ignorespaces Fourier global é cego para a posição. Os espectros não dizem onde as bordas estão.}}{266}{figure.caption.198}%
\contentsline {figure}{\numberline {5.16}{\ignorespaces Funções da Wavelet (ψ). Note como elas rapidamente decaem para zero (suporte compacto), ao contrário das senoides infinitas de Fourier.}}{268}{figure.caption.199}%
\contentsline {figure}{\numberline {5.17}{\ignorespaces Diagrama da decomposição wavelet 2D em dois níveis.}}{268}{figure.caption.200}%
\contentsline {figure}{\numberline {5.18}{\ignorespaces Decomposição wavelet 2D de 2 níveis com wavelet Haar: subbandas LL, LH, HL, HH em cada nível. As subbandas de detalhe revelam estruturas orientadas em diferentes escalas.}}{269}{figure.caption.201}%
\contentsline {figure}{\numberline {5.19}{\ignorespaces Comparação entre famílias de wavelets: Haar, db4, sym4 e bior2.2. Subbanda LL₁ (aproximação) e HH₁ (diagonal) para cada escolha, ilustrando o compromisso entre compactação e suavidade.}}{270}{figure.caption.202}%
\contentsline {figure}{\numberline {5.20}{\ignorespaces Reconstrução wavelet com limiamento de coeficientes (hard thresholding): à medida que o limiar aumenta, mais detalhes são zerificados, produzindo imagens progressivamente mais suaves. Métrica PSNR quantifica a perda de qualidade.}}{271}{figure.caption.203}%
\contentsline {figure}{\numberline {5.21}{\ignorespaces O Alfabeto Visual do JPEG: As 64 funções de base da DCT-II. O coeficiente DC fica no topo esquerdo (suave). Ao descer e avançar à direita, a oscilação espacial aumenta drasticamente.}}{274}{figure.caption.205}%
\contentsline {figure}{\numberline {5.22}{\ignorespaces DCT 2D em bloco 8×8: coeficientes e reconstrução progressiva.}}{276}{figure.caption.206}%
\contentsline {figure}{\numberline {5.23}{\ignorespaces Pipeline JPEG simplificado: DCT em blocos 8×8, quantização com diferentes fatores de qualidade e reconstrução via IDCT. O artefato de blocos torna-se visível para qualidades baixas (Q=10--20).}}{278}{figure.caption.207}%
\contentsline {figure}{\numberline {5.24}{\ignorespaces Simulador interativo de compressão DCT-JPEG: ajuste o fator de qualidade e visualize em tempo real os coeficientes zerados, o bloco reconstruído e o erro de quantização.}}{279}{figure.caption.208}%
\contentsline {figure}{\numberline {5.25}{\ignorespaces Forte compressão (Q=10). À esquerda o artefato de bloco clássico da DCT. À direita, a suavização de bordas característica do WebP.}}{280}{figure.caption.211}%
\contentsline {figure}{\numberline {5.26}{\ignorespaces Curva taxa-distorção: PSNR vs tamanho de arquivo para JPEG, WebP e PNG.}}{282}{figure.caption.212}%
\contentsline {figure}{\numberline {5.27}{\ignorespaces Mapas de erro JPEG em diferentes qualidades: artefatos de bloco nas bordas.}}{283}{figure.caption.213}%
\contentsline {figure}{\numberline {5.28}{\ignorespaces Pipeline completo de remoção de ruído misto: (1) ruído gaussiano + periódico adicionado; (2) picos periódicos identificados no espectro; (3) filtro notch de supressão suave (Gaussiana) aplicado; (4) filtro bilateral remove o gaussiano residual.}}{285}{figure.caption.214}%
\contentsline {figure}{\numberline {5.29}{\ignorespaces Mapa conceitual do domínio da frequência.}}{286}{figure.caption.215}%
