\contentsline {figure}{\numberline {3.1}{\ignorespaces \emph {Mandrill} (\emph {Mandrillus sphinx}) fotografado em ambiente natural na África do Sul. A imagem possui resolução de 500 px e contém metadados EXIF com coordenadas GPS aproximadas (-26.20473, 28.22662). Crédito: Carlos Guilherme Rodrigues (CC BY-SA 3.0).}}{115}{figure.caption.63}%
\contentsline {figure}{\numberline {3.2}{\ignorespaces Operações aritméticas saturadas: adição de constante (clareamento) e subtração de constante (escurecimento com saturação em 0).}}{116}{figure.caption.65}%
\contentsline {figure}{\numberline {3.3}{\ignorespaces Retrato de um leopardo (\emph {Panthera pardus}) em ambiente natural. Crédito: C. Brück (CC BY-SA 4.0).}}{117}{figure.caption.67}%
\contentsline {figure}{\numberline {3.4}{\ignorespaces \emph {Alpha blending} entre recortes alinhados de mandrill e do leopardo (Figure~\ref {fig-03-leopardo}) para diferentes valores de α. Em α=1 vê-se apenas mandrill; em α=0, apenas o leopardo; valores intermediários fundem os olhares das duas imagens proporcionalmente.}}{118}{figure.caption.68}%
\contentsline {figure}{\numberline {3.5}{\ignorespaces Operações lógicas bit a bit com máscara circular: AND (isolamento da ROI), OR (iluminação da ROI) e NOT (negativo).}}{119}{figure.caption.70}%
\contentsline {figure}{\numberline {3.6}{\ignorespaces Histogramas da imagem original, de uma versão escurecida e de uma versão clareada. Os valores na segunda linha indicam a quantidade de pixels saturados em 0 (preto) e 255 (branco).}}{120}{figure.caption.73}%
\contentsline {figure}{\numberline {3.7}{\ignorespaces Equalização de histograma em imagem 5×5 com 3 bits (L=8): imagem original com tons concentrados em \{2,3,4\}, imagem equalizada com tons redistribuídos para \{1,5,7\}, e os respectivos histogramas evidenciando o espalhamento das frequências.}}{122}{figure.caption.75}%
\contentsline {figure}{\numberline {3.8}{\ignorespaces Equalização de histograma: mm.equalize (global via CDF) vs.~CLAHE (adaptativa com limitação de contraste). Os histogramas revelam o espalhamento progressivo das intensidades.}}{124}{figure.caption.76}%
\contentsline {figure}{\numberline {3.9}{\ignorespaces Especificação de histograma: mandril mapeada para o perfil tonal do leopardo. A CDF da saída aproxima a CDF de referência.}}{125}{figure.caption.78}%
\contentsline {figure}{\numberline {3.10}{\ignorespaces Correlação com \emph {kernel} de média 3×3: versão didática (mm.conv0) vs.~vetorizada (mm.conv via cv2.filter2D). A diferença máxima de 39 ocorre nas bordas.}}{132}{figure.caption.83}%
\contentsline {figure}{\numberline {3.11}{\ignorespaces \emph {Patch} 5×5 extraído da imagem do leopardo (posição {[}250:255, 250:255{]}). A janela amarela destaca a vizinhança 3×3 centrada no pixel {[}1,1{]} onde a correlação será calculada.}}{133}{figure.caption.84}%
\contentsline {figure}{\numberline {3.12}{\ignorespaces Filtro de média com \emph {kernels} de tamanho crescente (3×3, 7×7, 15×15). O borramento das bordas aumenta com o tamanho do \emph {kernel}.}}{134}{figure.caption.86}%
\contentsline {figure}{\numberline {3.13}{\ignorespaces \emph {Kernel} Gaussiano 5×5 (σ=1): pesos normalizados, maiores no centro e decrescentes radialmente. A grade facilita a leitura de cada coeficiente.}}{135}{figure.caption.88}%
\contentsline {figure}{\numberline {3.14}{\ignorespaces Comparação entre filtro de média e Gaussiano (\emph {kernel} 9×9, σ=0). O Gaussiano preserva melhor as bordas, visível no detalhe do rosto.}}{136}{figure.caption.89}%
\contentsline {figure}{\numberline {3.15}{\ignorespaces Simulador: Filtragem Espacial de Realce 1D.}}{137}{figure.caption.91}%
\contentsline {figure}{\numberline {3.16}{\ignorespaces \emph {Kernel} Laplaciano w4 aplicado ao \emph {patch} 5×5: a janela amarela destaca a vizinhança 3×3 onde o operador de segunda derivada é calculado.}}{139}{figure.caption.95}%
\contentsline {figure}{\numberline {3.17}{\ignorespaces Laplaciano aplicado à imagem do leopardo: resposta bruta (bordas detectadas) com w4 e w8, e imagens realçadas pela subtração do Laplaciano. w8 é mais sensível às diagonais.}}{140}{figure.caption.96}%
\contentsline {figure}{\numberline {3.18}{\ignorespaces Operador de Sobel na imagem do leopardo: Gx detecta bordas verticais, Gy detecta bordas horizontais, e a magnitude \textbar ∇f\textbar {} combina ambos, revelando todas as bordas independente de direção.}}{142}{figure.caption.100}%
\contentsline {figure}{\numberline {3.19}{\ignorespaces Operador de Prewitt: Gx, Gy e magnitude --- comparável ao Sobel, mas sem ponderação Gaussiana perpendicular.}}{142}{figure.caption.102}%
\contentsline {figure}{\numberline {3.20}{\ignorespaces Realce de nitidez por \emph {Unsharp Masking} na imagem do leopardo: a imagem suavizada é subtraída da original para gerar a máscara de alta frequência, que é então reintroduzida para realçar bordas e detalhes.}}{144}{figure.caption.104}%
\contentsline {figure}{\numberline {3.21}{\ignorespaces \emph {Unsharp Masking} na imagem do leopardo com σ=1 e k variando de 0.5 a 8.0. Para k\textgreater 2 surgem artefatos nas bordas (halos) e o ruído de fundo começa a ser visível.}}{145}{figure.caption.105}%
\contentsline {figure}{\numberline {3.22}{\ignorespaces Detector de Canny com diferentes pares de limiar: limiares baixos capturam mais bordas (inclusive ruído); limiares altos retêm apenas as bordas mais fortes.}}{146}{figure.caption.106}%
\contentsline {figure}{\numberline {3.23}{\ignorespaces Ruído sal e pimenta com densidades crescentes (2\%, 5\%, 10\%). O parâmetro prob indica a fração total de pixels corrompidos, metade sal (255) e metade pimenta (0).}}{147}{figure.caption.107}%
\contentsline {figure}{\numberline {3.24}{\ignorespaces Comparação de filtros para remoção de ruído sal e pimenta (10\%): Gaussiano, Média, Mediana, Bilateral e Morfológico. Linha superior: imagens completas; linha inferior: crop da região de interesse.}}{150}{figure.caption.109}%
\contentsline {figure}{\numberline {3.25}{\ignorespaces \emph {Pipeline} de pré-processamento: CLAHE → Gaussiano → Canny. Cada etapa prepara a imagem para a seguinte, resultando em bordas limpas e bem definidas.}}{151}{figure.caption.110}%
