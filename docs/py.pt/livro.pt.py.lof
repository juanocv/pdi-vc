\contentsline {figure}{\numberline {3.30}{\ignorespaces Simulador: Aplicação de Máscara AND Binária}}{163}{figure.caption.115}%
\contentsline {figure}{\numberline {3.31}{\ignorespaces Simulador: Filtro de Média com \emph {Kernel} N×N}}{165}{figure.caption.116}%
