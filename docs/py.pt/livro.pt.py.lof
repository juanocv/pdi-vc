\contentsline {figure}{\numberline {4.1}{\ignorespaces Imagem com moedas de vários tipos. Crédito: GAZI.MD.AHAD (CC BY-SA 4.0).}}{178}{figure.caption.123}%
\contentsline {figure}{\numberline {4.2}{\ignorespaces Comparação dos pré-processamentos: imagem \textbar {} histograma+T* \textbar {} σ²B(T) \textbar {} Otsu. A melhor separação bimodal indica o limiar mais confiável.}}{181}{figure.caption.124}%
\contentsline {figure}{\numberline {4.3}{\ignorespaces Elemento estruturante em formato de cruz (\(B_{\text {cruz}}\)) utilizado para conectividade-4.}}{183}{figure.caption.126}%
\contentsline {figure}{\numberline {4.4}{\ignorespaces Erosão e dilatação em imagem binária 10×10 com elemento estruturante `L' assimétrico 3×3. Validação da dualidade erosão--dilatação.}}{189}{figure.caption.128}%
\contentsline {figure}{\numberline {4.5}{\ignorespaces Simulador interativo de erosão morfológica: visualização do critério de inclusão do elemento estruturante assimétrico \(B_L\) sobre a imagem binária \(A\).}}{190}{figure.caption.129}%
\contentsline {figure}{\numberline {4.6}{\ignorespaces Abertura, fechamento, composição e filtro sequencial alternado aplicados à binarização Otsu das moedas com CLAHE. Elemento estruturante: disco 13×13.}}{192}{figure.caption.132}%
\contentsline {figure}{\numberline {4.7}{\ignorespaces Simulador interativo de dilatação geodésica: o marcador \(f\) (verde) propaga-se passo a passo pelos caminhos livres da máscara \(g\), sem atravessar paredes --- ilustrando como \( delta_g^{(n)}(f)\) encontra a saída do labirinto.}}{193}{figure.caption.134}%
\contentsline {figure}{\numberline {4.8}{\ignorespaces Resolução de labirinto via Operações Complementares: Invertendo a máscara e o marcador no início do \emph {pipeline}, o fluxo é resolvido diretamente no domínio complementar através de mm.cero e mm.suprec, eliminando re-inversões redundantes.}}{196}{figure.caption.136}%
\contentsline {figure}{\numberline {4.9}{\ignorespaces \emph {Pipeline} de Reconstrução Morfológica por Dilatação Condicionada: a máscara contém dois objetos, o marcador isola apenas o núcleo do objeto principal, e as iterações subsequentes em laço reconstroem sua forma exata até a convergência.}}{198}{figure.caption.138}%
\contentsline {figure}{\numberline {4.10}{\ignorespaces \emph {Pipeline} de preenchimento de buracos (\emph {clohole}): o marcador é obtido a partir da borda da imagem e restringido ao complemento \(f^c\). As iterações de dilatação geodésica reconstruem o fundo externo; após a complementação final, os buracos internos ficam preenchidos.}}{200}{figure.caption.141}%
\contentsline {figure}{\numberline {4.11}{\ignorespaces \emph {Pipeline} de eliminação de estruturas de borda (\emph {edgeoff}): o marcador captura as raízes conectadas às extremidades da matriz, a reconstrução delimita a extensão desses elementos e a subtração booleana preserva unicamente os objetos totalmente internos.}}{201}{figure.caption.142}%
\contentsline {figure}{\numberline {4.12}{\ignorespaces \emph {Pipeline} completo de segmentação com CLAHE: Otsu → abertura (r=9) → clohole → abertura (r=33) → edgeoff.}}{202}{figure.caption.143}%
\contentsline {figure}{\numberline {4.13}{\ignorespaces Simulador interativo avançado de morfologia com elemento estruturante editável e perfil 1D.}}{203}{figure.caption.147}%
\contentsline {figure}{\numberline {4.14}{\ignorespaces Morfologia em tons de cinza e seus respectivos histogramas. A erosão reduz intensidades locais, a dilatação as amplia, o gradiente destaca bordas, e os operadores Top-hat e Black-hat evidenciam detalhes locais brilhantes e escuros. Elemento estruturante: disco de diâmetro 19.}}{205}{figure.caption.148}%
\contentsline {figure}{\numberline {4.15}{\ignorespaces Algoritmo de rotulação por \emph {flood-fill} com pilha: passo a passo, cards, linha do tempo, código Python e fluxograma.}}{207}{figure.caption.150}%
\contentsline {figure}{\numberline {4.16}{\ignorespaces Simulador interativo de rotulação de componentes conexas (\emph {connected component labeling}): visualização da expansão flood-fill, conectividade-4 e conectividade-8.}}{207}{figure.caption.151}%
\contentsline {figure}{\numberline {4.17}{\ignorespaces Efeito da conectividade na rotulação: a imagem binária 10×10 contém pixels diagonalmente adjacentes. Com conectividade-4, esses pixels formam componentes distintas; com conectividade-8, fundem-se em uma única componente.}}{208}{figure.caption.152}%
\contentsline {figure}{\numberline {4.18}{\ignorespaces Algoritmo da Transformada de Distância: passo a passo, cards, linha do tempo, código Python e fluxograma.}}{209}{figure.caption.153}%
\contentsline {figure}{\numberline {4.19}{\ignorespaces Simulador interativo da Transformada de Distância (TD) iterativa via erosão em tons de cinza. Pixels fora da imagem agora assumem o valor máximo (144), propagando os custos apenas a partir do fundo interno.}}{210}{figure.caption.154}%
\contentsline {figure}{\numberline {4.20}{\ignorespaces Transformada de Distância em imagem binária 10×10. Esquerda: imagem original (\emph {foreground} = 255). Centro: mm.dist1 iterativa (erosões com elemento cruz). Direita: mm.dist (L2 Euclidiana).}}{211}{figure.caption.155}%
\contentsline {figure}{\numberline {4.21}{\ignorespaces Simulador interativo 2D (4x4) com sincronização estrita de filas de propagação horizontal (b) para obter a convergência exata descrita no artigo.}}{212}{figure.caption.156}%
\contentsline {figure}{\numberline {4.22}{\ignorespaces Menor caminho geodésico em um labirinto. As distâncias geodésicas são calculadas a partir da entrada e da saída usando mm.gdist. Os pixels cujo somatório das duas distâncias é igual à distância mínima entre os marcadores pertencem a um caminho ótimo.}}{213}{figure.caption.157}%
\contentsline {figure}{\numberline {4.23}{\ignorespaces Algoritmo Didático de \emph {Watershed} por Crescimento de Regiões Limitado por Máscara: passo a passo, cards, linha do tempo, código Python e fluxograma.}}{214}{figure.caption.158}%
\contentsline {figure}{\numberline {4.24}{\ignorespaces Simulador interativo do Algoritmo \emph {Watershed} por propagação morfológica. Desenhe a máscara, posicione os marcadores e ajuste o Elemento Estruturante para observar a inundação. Quando as bacias se encontram simultaneamente, o empate é resolvido assumindo uma das regiões de forma aleatória.}}{215}{figure.caption.159}%
\contentsline {figure}{\numberline {4.25}{\ignorespaces \emph {Pipeline} \emph {watershed} delimitado por máscara em imagem binária 20×20.}}{216}{figure.caption.160}%
\contentsline {figure}{\numberline {4.26}{\ignorespaces \emph {Pipeline} \emph {Watershed} para separação de moedas sobrepostas: da máscara binária dilatada até os contornos finais anotados sobre a imagem original.}}{218}{figure.caption.161}%
\contentsline {figure}{\numberline {4.27}{\ignorespaces Componentes conexos extraídos após o \emph {pipeline} CLAHE → Otsu → limpeza morfológica. Cada objeto é colorido com cor distinta e anotado com sua área em pixels.}}{220}{figure.caption.162}%
\contentsline {figure}{\numberline {4.28}{\ignorespaces Contornos extraídos com \emph {findContours}. Cada moeda é anotada com sua circularidade --- valores próximos de 1 confirmam forma circular.}}{222}{figure.caption.163}%
\contentsline {figure}{\numberline {4.29}{\ignorespaces \emph {Bounding boxes} derivadas dos componentes conexos sobrepostas à imagem original. As anotações são exportadas no formato YOLO (\emph {classe cx cy w h}), com coordenadas normalizadas para o intervalo {[}0,1{]}.}}{223}{figure.caption.164}%
