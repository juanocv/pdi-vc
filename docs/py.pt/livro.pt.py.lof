\contentsline {figure}{\numberline {3.1}{\ignorespaces 500px provided description: Carlos Guilherme Rodrigues {[}\#animals ,\#africa ,\#big 5 ,\#soud africa{]} GPS: (-26.20473, 28.22662). Crédito: Carlos Guilherme Rodrigues (CC BY-SA 3.0).}}{101}{figure.caption.61}%
\contentsline {figure}{\numberline {3.2}{\ignorespaces Operações aritméticas saturadas: adição de constante (clareamento) e subtração de constante (escurecimento com saturação em 0).}}{102}{figure.caption.63}%
\contentsline {figure}{\numberline {3.3}{\ignorespaces Leopard (Panthera pardus) GPS: (-19.14020, 23.81487). Crédito: C. Brück (CC BY-SA 4.0).}}{103}{figure.caption.65}%
\contentsline {figure}{\numberline {3.4}{\ignorespaces \emph {Alpha blending} entre recortes alinhados de mandrill e do leopardo (Figure~\ref {fig-03-leopardo}) para diferentes valores de α. Em α=1 vê-se apenas mandrill; em α=0, apenas o leopardo; valores intermediários fundem os olhares das duas imagens proporcionalmente.}}{104}{figure.caption.66}%
\contentsline {figure}{\numberline {3.5}{\ignorespaces Operações lógicas bit a bit com máscara circular: NOT (negativo), AND (isolamento da ROI) e OR (iluminação da ROI).}}{105}{figure.caption.68}%
\contentsline {figure}{\numberline {3.6}{\ignorespaces Histogramas da imagem original, de uma versão escurecida e de uma versão clareada. Os valores entre parênteses indicam a quantidade de pixels saturados em 0 (preto) e 255 (branco).}}{106}{figure.caption.71}%
\contentsline {figure}{\numberline {3.7}{\ignorespaces Equalização de histograma em imagem 5×5 com 3 bits (L=8): imagem original com tons concentrados em \{2,3,4\}, imagem equalizada com tons redistribuídos para \{1,5,7\}, e os respectivos histogramas evidenciando o espalhamento das frequências.}}{108}{figure.caption.73}%
\contentsline {figure}{\numberline {3.8}{\ignorespaces Equalização de histograma: mm.equalize (global via CDF) vs.~CLAHE (adaptativa com limitação de contraste). Os histogramas revelam o espalhamento progressivo das intensidades.}}{109}{figure.caption.74}%
\contentsline {figure}{\numberline {3.9}{\ignorespaces Especificação de histograma: mandril mapeada para o perfil tonal do leopardo. A CDF da saída aproxima a CDF de referência.}}{110}{figure.caption.76}%
\contentsline {figure}{\numberline {3.10}{\ignorespaces Correlação com kernel de média 3×3: versão didática (mm.conv0) vs.~vetorizada (mm.conv via cv2.filter2D). A diferença máxima de 27 ocorre nas bordas, onde o tratamento de padding difere.}}{112}{figure.caption.80}%
\contentsline {figure}{\numberline {3.11}{\ignorespaces Patch 5×5 extraído da imagem do mandrill (posição {[}250:255, 250:255{]}). A janela amarela destaca a vizinhança 3×3 centrada no pixel {[}1,1{]} onde a correlação será calculada.}}{113}{figure.caption.81}%
\contentsline {figure}{\numberline {3.12}{\ignorespaces Filtro de média com kernels de tamanho crescente (3×3, 7×7, 15×15). O borramento das bordas aumenta com o tamanho do kernel.}}{114}{figure.caption.83}%
\contentsline {figure}{\numberline {3.13}{\ignorespaces Kernel Gaussiano 5×5 (σ=1): pesos normalizados, maiores no centro e decrescentes radialmente. A grade facilita a leitura de cada coeficiente.}}{115}{figure.caption.85}%
\contentsline {figure}{\numberline {3.14}{\ignorespaces Comparação entre filtro de média e Gaussiano (janela 9×9, σ=0 para cálculo automático). O Gaussiano preserva melhor as bordas, visível no detalhe do rosto.}}{116}{figure.caption.86}%
\contentsline {figure}{\numberline {3.15}{\ignorespaces }}{118}{figure.caption.91}%
\contentsline {figure}{\numberline {3.16}{\ignorespaces Laplaciano aplicado à imagem do mandrill: resposta bruta (bordas detectadas) com w4 e w8, e imagens realçadas pela subtração do Laplaciano. w8 é mais sensível às diagonais.}}{118}{figure.caption.92}%
\contentsline {figure}{\numberline {3.17}{\ignorespaces Operador de Sobel na imagem mandrill: Gx detecta bordas verticais, Gy detecta bordas horizontais, e a magnitude \textbar ∇f\textbar {} combina ambos, revelando todas as bordas independente de direção.}}{120}{figure.caption.96}%
\contentsline {figure}{\numberline {3.18}{\ignorespaces Unsharp Masking na imagem do mandrill com σ=1 e k variando de 0.5 a 3.0. Para k\textgreater 2 surgem artefatos nas bordas (halos) e o ruído de fundo começa a ser visível.}}{122}{figure.caption.98}%
\contentsline {figure}{\numberline {3.19}{\ignorespaces Ruído sal e pimenta com densidades crescentes (2\%, 5\%, 10\%). O parâmetro prob indica a fração total de pixels corrompidos, metade sal (255) e metade pimenta (0).}}{123}{figure.caption.99}%
\contentsline {figure}{\numberline {3.20}{\ignorespaces Comparação de filtros para remoção de ruído sal e pimenta (10\%): Gaussiano, Média, Mediana, Bilateral e Morfológico. Linha superior: imagens completas; linha inferior: crop da região de interesse.}}{126}{figure.caption.101}%
\contentsline {figure}{\numberline {3.21}{\ignorespaces Pipeline de pré-processamento: CLAHE → Gaussiano → Canny. Cada etapa prepara a imagem para a seguinte, resultando em bordas limpas e bem definidas.}}{127}{figure.caption.102}%
\contentsline {figure}{\numberline {3.22}{\ignorespaces Simulador: Distâncias Euclidiana, \emph {City-block} e \emph {Chessboard}}}{130}{figure.caption.103}%
