"        px.forEach(p => {\n",
"            let cell = document.createElement('div'); cell.style.cssText = `width:42px;height:42px;background:rgb(${p},${p},${p});color:white;display:flex;align-items:center;justify-content:center;font-size:10px;`; cell.innerText = p; go.appendChild(cell);\n",
