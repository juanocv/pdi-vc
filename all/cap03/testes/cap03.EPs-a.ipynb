"        let hist = Array(256).fill(0); px.forEach(v => hist[v]++);\n",
"        let fda = Array(256).fill(0), sum = 0; for(let i=0;i<256;i++) { sum += hist[i]; fda[i] = sum; }\n",
"        let fmin = fda.find(v => v > 0);\n",
"        gn.innerHTML = '';\n",
