"            let r = Math.round(255 * (fda[p] - fmin) / (16 - fmin)); if (16 === fmin) r = 0;\n",
"            let cell = document.createElement('div'); cell.style.cssText = `width:42px;height:42px;background:rgb(${r},${r},${r});color:${r>128?'black':'white'};display:flex;align-items:center;justify-content:center;font-size:10px;`; cell.innerText = r; gn.appendChild(cell);\n",
"        });\n",
"    };\n",
"    init();\n",
"})();\n",
"\n",
"""")"
